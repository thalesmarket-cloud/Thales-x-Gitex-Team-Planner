rules_version = '2';

// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: members
// Document ID: auto-generated or manual ID
// Fields:
//   - id: string (required)
//   - name: string (required)
//   - role: string (required)
//   - poloSize: string (optional)
//   - phone: string (optional)
//   - email: string (optional)
//   - color: string (required)
//
// Collection: assignments
// Document ID: auto-generated (usually memberId + shiftId)
// Fields:
//   - memberId: string (required)
//   - shiftId: string (required)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "thales.market@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidMember(data) {
      return data.keys().hasAll(['id', 'name', 'role', 'color']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role is string &&
             data.color is string;
    }

    function isValidAssignment(data) {
      return data.keys().hasAll(['memberId', 'shiftId']) &&
             data.memberId is string &&
             data.shiftId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /members/{memberId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidMember(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidAssignment(request.resource.data);
      allow delete: if isAuthenticated();
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
